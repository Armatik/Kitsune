<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="kitsune">
  <schema id="net.armatik.Kitsune" path="/net/armatik/Kitsune/">
    <key name="preferred-quality" type="s">
      <default>'1080'</default>
      <summary>Preferred video quality</summary>
      <description>Preferred HLS stream quality: 1080, 720, or 480</description>
    </key>
    <key name="volume" type="d">
      <default>1.0</default>
      <summary>Player volume</summary>
      <description>Player volume level (0.0 to 1.0)</description>
      <range min="0.0" max="1.0"/>
    </key>
    <key name="release-page-style" type="s">
      <default>'classic'</default>
      <summary>Release page style</summary>
      <description>Visual style for the release page: classic or accent</description>
    </key>
    <key name="accent-fade-duration" type="i">
      <default>2000</default>
      <summary>Accent fade-in duration</summary>
      <description>Duration of accent gradient fade-in animation in milliseconds (100–3000)</description>
      <range min="100" max="3000"/>
    </key>
    <key name="accent-mobile-enabled" type="b">
      <default>false</default>
      <summary>Enable accent in mobile mode</summary>
      <description>Show accent gradient in narrow/mobile layout (experimental)</description>
    </key>
    <key name="accent-glass-effect" type="b">
      <default>false</default>
      <summary>Glass effect</summary>
      <description>Overlay subtle noise on the accent gradient for a frosted glass look</description>
    </key>
    <key name="accent-color-points" type="i">
      <default>4</default>
      <summary>Accent color points</summary>
      <description>Number of color gradient points (2–6)</description>
      <range min="2" max="6"/>
    </key>
    <key name="player-show-close-button" type="b">
      <default>false</default>
      <summary>Show close button in player</summary>
      <description>Show close window button in the video player top bar</description>
    </key>
    <key name="episodes-view" type="s">
      <default>'list'</default>
      <summary>Episodes view mode</summary>
      <description>How to display episodes: list or grid</description>
    </key>
    <key name="window-width" type="i">
      <default>900</default>
      <summary>Window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>600</default>
      <summary>Window height</summary>
    </key>
  </schema>
</schemalist>
