{
    "app-id": "net.armatik.Kitsune",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "kitsune",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--socket=pulseaudio"
    ],
    "modules": [
        {
            "name": "kitsune",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "../.."
                }
            ]
        }
    ]
}
